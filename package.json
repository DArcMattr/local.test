{
  "author": "David Arceneaux <david@davidthemachine.org>",
  "license": "BSD-2-Clause",
  "name": "Scratch Site",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/DArcMattr/local.test"
  },
  "version": "3.0.0",
  "description": "",
  "type": "module",
  "main": "htdocs/js/main.js",
  "devDependencies": {
    "browser-sync": "latest",
    "eslint": "latest",
    "eslint-plugin-jsdoc": "latest",
    "stylelint": "latest",
    "stylelint-config-recommended": "latest"
  },
  "stylelint": {
    "extends": [
      "stylelint-config-recommended"
    ]
  },
  "browser-sync": {
    "cors": true,
    "files": ["./htdocs/**/*"],
    "ghostMode": false,
    "open": false,
    "notify": true,
    "proxy": {
      "target": "https://${BROWSERSYNC_HOST:-local.localhost}",
      "proxyRes": [
        "function(proxyRes, req, res) { res.setHeader('Access-Control-Allow-Origin', '*'); }"
      ]
    },
    "https": {
      "key": "./tls/${BROWSERSYNC_HOST:-local}-key.pem",
      "cert": "./tls/${BROWSERSYNC_HOST:-local}.pem"
    }
  },
  "eslintConfig": {
    "env": {
      "es6": true
    },
    "parserOptions": {
      "ecmaVersion": "latest",
      "sourceType": "module"
    },
    "plugins": [
      "jsdoc"
    ]
  },
  "scripts": {
    "tls": "mkdir -p ./tls && mkcert -cert-file ./tls/${BROWSERSYNC_HOST:-local}.pem -key-file ./tls/${BROWSERSYNC_HOST:-local}-key.pem ${BROWSERSYNC_HOST:-local.localhost} localhost 127.0.0.1",
    "bsync": "browser-sync start --config package.json",
    "lint": "npm run lint:style && npm run lint:js",
    "lint:style": "stylelint htdocs/style/**/*.css",
    "lint:js": "eslint htdocs/js/**/*.js",
    "start": "npm run bsync"
  }
}

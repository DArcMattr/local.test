{
  "author": "David Arceneaux <david@davidthemachine.org>",
  "license": "BSD-2-Clause",
  "name": "Scratch Site",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/DArcMattr/local.test"
  },
  "version": "3.0.0",
  "description": "",
  "type": "module",
  "main": "htdocs/js/main.js",
  "devDependencies": {
    "browser-sync": "latest",
    "eslint": "latest",
    "eslint-plugin-jsdoc": "latest",
    "stylelint": "latest",
    "stylelint-config-recommended": "latest"
  },
  "stylelint": {
    "extends": [
      "stylelint-config-recommended"
    ]
  },
  "eslintConfig": {
    "env": {
      "es6": true
    },
    "parserOptions": {
      "ecmaVersion": "latest",
      "sourceType": "module"
    },
    "plugins": [
      "jsdoc"
    ]
  },
  "scripts": {
    "tls": "mkdir -p ./tls && mkcert -cert-file ./tls/${HOST:-local}.pem -key-file ./tls/${HOST:-local}-key.pem ${HOST:-local.localhost} localhost 127.0.0.1",
    "bsync": "node script/bsync.js",
    "lint": "npm run lint:style && npm run lint:js",
    "lint:style": "stylelint htdocs/style/**/*.css",
    "lint:js": "eslint htdocs/js/**/*.js",
    "start": "npm run bsync"
  }
}
